{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/admin",
      "destination": "/frontend/dashboard/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/frontend/dashboard/:path*"
    },
    {
      "source": "/fan",
      "destination": "/frontend/fan-view/index.html"
    },
    {
      "source": "/fan/:path*",
      "destination": "/frontend/fan-view/:path*"
    },
    {
      "source": "/report",
      "destination": "/frontend/report/index.html"
    },
    {
      "source": "/report/:path*",
      "destination": "/frontend/report/:path*"
    },
    {
      "source": "/submission",
      "destination": "/submission.html"
    },
    {
      "source": "/",
      "destination": "/api/index.py"
    }
  ]
}
